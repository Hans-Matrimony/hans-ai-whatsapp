# ==========================================
# Hans AI WhatsApp Webhook - Environment Variables
# ==========================================

# Service Type: web, worker, beat, or flower
SERVICE_TYPE=web

# WhatsApp Meta API Configuration
WHATSAPP_VERIFY_TOKEN=random_token
WHATSAPP_PHONE_ID=your_phone_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_account_id

# WhatsApp Business Number (E.164 format, without +)
WHATSAPP_PHONE_NUMBER=91xxxxxxxxxx

# OpenClaw Gateway Configuration
OPENCLAW_URL=your_openclaw_url
OPENCLAW_GATEWAY_TOKEN=your_random_32bit_token
OPENCLAW_TIMEOUT=60

# Mongo Logger Configuration (for chat history storage)
MONGO_LOGGER_URL=your_mongologger_url

# Subscription Service Configuration (for access control)
SUBSCRIPTIONS_URL=your_subscriptions_service_url
SUBSCRIPTION_TEST_NUMBER=9760347653

# Proactive Nudge Configuration (TESTING MODE)
# Set to specific phone number (e.g., +919760347653) to only send nudges to that number
# Leave empty or comment out to send nudges to all eligible users
PROACTIVE_NUDGE_TEST_NUMBER=+919760347653

# Admin API Configuration
# API key for admin endpoints (e.g., /admin/send-inactive-template)
ADMIN_API_KEY=astro_admin_2026

# Message Processing
MESSAGE_TIMEOUT=30
MAX_MESSAGE_LENGTH=4096
ENABLE_MESSAGE_QUEUE=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Redis (for message queue)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Celery Configuration
CELERY_CONCURRENCY=20

# Flower Monitoring (for Celery task monitoring UI)
FLOWER_USER=admin
FLOWER_PASSWORD=change_me_please
FLOWER_PORT=5555

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGINS=*

# Features
ENABLE_MEDIA_HANDLING=true
ENABLE_INTERACTIVE_MESSAGES=true
ENABLE_MESSAGE_STATUS=false

# PDF and Audio Analysis Features (default: false for safe rollout)
ENABLE_PDF_ANALYSIS=false
ENABLE_AUDIO_EMOTION_DETECTION=false

# AI-Generated Enforcement Messages (default: false for safe rollout)
# Generates personalized, contextual paywall and payment nudge messages
ENABLE_AI_ENFORCEMENT=false
AI_ENFORCEMENT_CACHE_TTL=86400  # 24 hours
AI_ENFORCEMENT_TIMEOUT=10.0     # Max wait time for AI generation (seconds)
AI_ENFORCEMENT_FALLBACK=true    # Use hardcoded messages if AI fails

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY=1
